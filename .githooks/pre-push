#!/usr/bin/env bash
# Local pre-push hook to keep chatlog consistent before pushing.
# This runs only locally; it is not enforced on remote.
# It supports two optional behaviors:
# 1) If docs/pending_chat_append.txt exists and is non-empty, append its contents then remove it.
# 2) If AUTO_APPEND_CLIPBOARD=1 (env) or .chatlogrc contains AUTO_APPEND_CLIPBOARD=1, append clipboard.
# In both cases, it labels the append and stages the chatlog file.

set -euo pipefail

ROOT_DIR=$(git rev-parse --show-toplevel)
cd "$ROOT_DIR"

CHAT_FILE="docs/chatlog.md"
PENDING_FILE="docs/pending_chat_append.txt"
APPENDER="tools/append-chatlog.sh"
NEW_SESSION="tools/new-session-from-pending.sh"
BUILD_CHATLOG="tools/build-chatlog.sh"
LABEL="Pre-push"

# Load optional config
if [[ -f .chatlogrc ]]; then
  source .chatlogrc || true
fi

append_from_file() {
  local src="$1"
  if [[ -s "$src" ]]; then
    # Move pending into a session and rebuild chatlog from sessions
    bash "$NEW_SESSION" || true
    bash "$BUILD_CHATLOG" || true
    git add "$CHAT_FILE" docs/sessions || true
  fi
}

append_from_clipboard() {
  if command -v pbpaste >/dev/null 2>&1 || command -v xclip >/dev/null 2>&1 || command -v xsel >/dev/null 2>&1; then
    TMP_CLIP=$(mktemp)
    # capture clipboard and normalize
    if command -v pbpaste >/dev/null 2>&1; then
      pbpaste | tr -d '\r' > "$TMP_CLIP"
    elif command -v xclip >/dev/null 2>&1; then
      xclip -o -selection clipboard | tr -d '\r' > "$TMP_CLIP"
    else
      xsel --clipboard --output | tr -d '\r' > "$TMP_CLIP"
    fi

    if [[ -s "$TMP_CLIP" ]]; then
      # Skip if exact CID already present (idempotent path)
      if command -v shasum >/dev/null 2>&1; then
        CID=$(shasum -a 256 "$TMP_CLIP" | awk '{print $1}')
      elif command -v openssl >/dev/null 2>&1; then
        CID=$(openssl dgst -sha256 -r "$TMP_CLIP" | awk '{print $1}')
      else
        CID=""
      fi
      if [[ -n "$CID" && -f "$CHAT_FILE" ]] && grep -q "^\[CID:$CID\]$" "$CHAT_FILE"; then
        echo "[pre-push] Clipboard content already recorded (CID:$CID); skipping."
        rm -f "$TMP_CLIP"; return
      fi
      # Tail containment check: if a preview chunk is already in chatlog, skip
      if [[ -f "$CHAT_FILE" ]]; then
        PREVIEW=$(head -c 256 "$TMP_CLIP")
        if [[ -n "$PREVIEW" ]] && grep -Fq -- "$PREVIEW" "$CHAT_FILE"; then
          echo "[pre-push] Clipboard content appears already present in chatlog; skipping."
          rm -f "$TMP_CLIP"; return
        fi
      fi
      # Write clipboard into pending and adopt session-based flow
      cat "$TMP_CLIP" > "$PENDING_FILE"
      bash "$NEW_SESSION" || true
      bash "$BUILD_CHATLOG" || true
      git add "$CHAT_FILE" docs/sessions || true
    fi
    rm -f "$TMP_CLIP" || true
  fi
}

# 1) Pending append file
append_from_file "$PENDING_FILE"

# 2) Optional clipboard append if enabled
if [[ "${AUTO_APPEND_CLIPBOARD:-0}" == "1" ]]; then
  append_from_clipboard
fi

# Continue push
exit 0
