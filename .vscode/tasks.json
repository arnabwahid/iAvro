{
  // VS Code tasks for chatlog/session workflow and CI helpers
  "version": "2.0.0",
  "tasks": [
    
    {
      "label": "New Session CC",
      "type": "shell",
      "command": "bash",
      "args": ["tools/new-session-cc.sh"],
      "problemMatcher": []
    },
    {
      "label": "Install Git Hooks (pre-push chatlog)",
      "type": "shell",
      "command": "bash",
      "args": ["tools/install-hooks.sh"],
      "problemMatcher": []
    },
    {
      "label": "Fetch Latest CI Logs (dev)",
      "type": "shell",
      "command": "bash",
      "args": ["tools/fetch-latest-ci-logs.sh", "dev", "./ci_logs"],
      "problemMatcher": []
    },
    {
      "label": "Open Latest CI Summary",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "SUMMARY=$(ls -1 ci_logs/**/ci_summary.txt 2>/dev/null | head -n1 || true); if [[ -n $SUMMARY ]]; then (command -v code >/dev/null && code -r \"$SUMMARY\") || ([[ $OSTYPE == darwin* ]] && open \"$SUMMARY\") || cat \"$SUMMARY\"; else echo 'No summary found. Run \"Fetch Latest CI Logs (dev)\" first.'; fi"
      ],
      "problemMatcher": []
    },
    {
      "label": "Check Last Build",
      "type": "shell",
      "command": "bash",
      "args": ["tools/check-last-build.sh", "dev"],
      "problemMatcher": []
    },
    {
      "label": "New Session (from continue chat)",
      "type": "shell",
      "command": "bash",
      "args": ["tools/new-session-from-continue-chat.sh"],
      "problemMatcher": []
    },
    {
      "label": "Build Chatlog (sessions → chatlog.md)",
      "type": "shell",
      "command": "bash",
      "args": ["tools/build-chatlog.sh"],
      "problemMatcher": []
    }
  ]
}
