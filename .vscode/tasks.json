{
  // VS Code tasks to append the current clipboard or stdin to the chat log
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Append Chatlog (Clipboard)",
      "type": "shell",
      "command": "bash",
      "args": ["tools/append-chatlog.sh", "--from-clipboard", "--commit"],
      "problemMatcher": []
    },
    {
      "label": "Append Chatlog (Stdin)",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "tools/append-chatlog.sh --commit"],
      "options": {
        "presentation": {
          "reveal": "always",
          "panel": "shared"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Append Chatlog (Clipboard — Codex CLI)",
      "type": "shell",
      "command": "bash",
      "args": ["tools/append-chatlog.sh", "--from-clipboard", "--label", "Codex CLI"],
      "problemMatcher": []
    },
    {
      "label": "Append Chatlog (Clipboard — ChatGPT Web)",
      "type": "shell",
      "command": "bash",
      "args": ["tools/append-chatlog.sh", "--from-clipboard", "--label", "ChatGPT Web"],
      "problemMatcher": []
    },
    {
      "label": "Append Chatlog (Clipboard — Prompt Label)",
      "type": "shell",
      "command": "bash",
      "args": [
        "tools/append-chatlog.sh",
        "--from-clipboard",
        "--label",
        "${input:chatlogLabel}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Append Chatlog (From File — Prompt Path & Label)",
      "type": "shell",
      "command": "bash",
      "args": [
        "tools/append-chatlog.sh",
        "--from-file",
        "${input:chatlogFile}",
        "--label",
        "${input:chatlogLabel}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Append & Open Chatlog (Clipboard — Prompt Label)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "tools/append-chatlog.sh --from-clipboard --label '${input:chatlogLabel}' && (command -v code >/dev/null && code -r docs/iavro_codex_chatlog.md || open docs/iavro_codex_chatlog.md)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Install Git Hooks (pre-push chatlog)",
      "type": "shell",
      "command": "bash",
      "args": ["tools/install-hooks.sh"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "chatlogLabel",
      "type": "promptString",
      "description": "Enter a label for this chat append (e.g., Codex CLI, ChatGPT Web, Manual)",
      "default": "Manual"
    },
    {
      "id": "chatlogFile",
      "type": "promptString",
      "description": "Path to a text file to append",
      "default": "tmp/chat_append.txt"
    }
  ]
}
